{
  "name": "dragonscope",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently -n api,web -c cyan,magenta \"npm run start:api\" \"vite\"",
    "start:api": "cd server && node apiServer.js",
    "start:prod": "npm run build && concurrently -n api,preview -c cyan,magenta \"npm run start:api\" \"vite preview\"",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently -n api,web,electron -c cyan,magenta,yellow \"npm run start:api\" \"vite\" \"wait-on http://localhost:5174 && ELECTRON_DEV=true electron .\"",
    "electron:build": "npm run build && electron-builder --mac",
    "service:install": "bash scripts/install-service.sh",
    "service:uninstall": "bash scripts/uninstall-service.sh"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.60.0",
    "alasql": "^4.17.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.5.3",
    "jsdom": "^28.0.0",
    "msw": "^2.12.9",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "@vitejs/plugin-react": {
      "@babel/types": "7.28.6"
    }
  },
  "build": {
    "appId": "com.dragonscope.app",
    "productName": "DragonScope",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "!server/logs/**",
      "!server/node_modules/**"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": ["dmg", "zip"],
      "icon": "public/favicon.svg"
    },
    "dmg": {
      "title": "DragonScope",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
