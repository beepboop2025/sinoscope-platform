# DragonScope Environment Variables
# Copy to .env and fill in your values

# Authentication (optional - app works without it)
VITE_CLERK_PUBLISHABLE_KEY=

# Backend API URL (leave empty when using Vite dev proxy, set for production)
VITE_API_BASE_URL=

# All API keys are now managed in backend/.env — no client-side keys needed.
# See backend/.env.example for the full list of backend configuration.
