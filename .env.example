# DragonScope Environment Variables
# Copy to .env and fill in your API keys

# Authentication (optional - app works without it)
VITE_CLERK_PUBLISHABLE_KEY=

# Market Data APIs
VITE_FRED_API_KEY=              # FRED (Federal Reserve) - bonds, economic data, commodities
VITE_ALPHA_VANTAGE_API_KEY=     # Alpha Vantage - stock quotes
VITE_FMP_API_KEY=               # Financial Modeling Prep - stock/china data
VITE_FINNHUB_API_KEY=           # Finnhub - stock quotes, news, WebSocket

# News APIs (cascade: Finnhub → NewsData → NewsAPI → WorldNews → GNews → RSS)
VITE_NEWSDATA_API_KEY=
VITE_NEWSAPI_API_KEY=
VITE_WORLD_NEWS_API_KEY=
VITE_GNEWS_API_KEY=

# Note: All API keys are optional. The app falls back to mock data generators
# when keys are missing or APIs are unreachable (Demo Mode).
