# DragonScope Backend Environment Variables
# Copy to .env and fill in your values

# === Database ===
DATABASE_URL=postgresql+asyncpg://dragonscope:dragonscope@localhost:5432/dragonscope

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Server ===
API_PORT=3456
DEBUG=false
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# === Authentication (Clerk) ===
# Leave empty for dev mode (auto-creates dev-user, no JWT verification)
CLERK_SECRET_KEY=
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# === API Keys (for Celery data collector) ===
# Free tier APIs (no key needed): Frankfurter, CoinGecko, DeFi Llama, GitHub, Reddit, SEC, arXiv
# Paid/limited APIs (add keys for enhanced data):
FRED_API_KEY=              # fred.stlouisfed.org - bonds, economic data, commodities
ALPHA_VANTAGE_API_KEY=     # alphavantage.co - stock quotes (25 req/day free)
FINNHUB_API_KEY=           # finnhub.io - stock quotes, news, candles
FMP_API_KEY=               # financialmodelingprep.com - stock data, profiles
GNEWS_API_KEY=             # gnews.io - news articles
NEWSDATA_API_KEY=          # newsdata.io - news articles
NEWSAPI_API_KEY=           # newsapi.org - news articles
WORLD_NEWS_API_KEY=        # worldnewsapi.com - news articles

# === Free LLM router (abstractive summaries / briefings) ===
# Adds an LLM tier to the NLP engine; falls back to rule-based on failure.
FREE_LLM_ENABLED=true       # set false to disable the LLM tier entirely
GROQ_API_KEY=               # console.groq.com - fastest free inference
CEREBRAS_API_KEY=           # cloud.cerebras.ai
GOOGLE_AI_STUDIO_API_KEY=   # aistudio.google.com - Gemini free tier
MISTRAL_API_KEY=            # console.mistral.ai
OPENROUTER_API_KEY=         # openrouter.ai - :free models

# === TimescaleDB ===
TIMESCALE_ENABLED=true
TIMESCALE_RETENTION_DAYS=90
TIMESCALE_COMPRESSION_AFTER_DAYS=7

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=200
