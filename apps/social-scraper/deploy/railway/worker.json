{
  "$schema": "https://railway.com/railway.schema.json",
  "build": { "builder": "DOCKERFILE", "dockerfilePath": "Dockerfile" },
  "deploy": {
    "startCommand": "celery -A core.scheduler worker --queues=collectors,processors,routing,health,default --concurrency=4 --loglevel=info --max-tasks-per-child=200",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
