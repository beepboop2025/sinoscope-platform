# DragonScope API server (apiServer.js) environment.

# ── Ports ──────────────────────────────────────────────────────────────────────
API_PORT=3456
DATA_SERVER_PORT=3457
NODE_ENV=development
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ── Auth (Clerk) ───────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=

# ── External data API keys ─────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
FRED_API_KEY=
GNEWS_API_KEY=
NEWSAPI_API_KEY=
NEWSDATA_API_KEY=
WORLD_NEWS_API_KEY=
APPSUMO_API_KEY=

# ── Free LLM router (powers /api/llm/chat for the browser SPA) ───────────────────
# Keys stay server-side; the SPA only POSTs prompts. Set any subset — the router
# uses only providers whose key is present. Order tried: groq, cerebras, google,
# mistral, openrouter.
GROQ_API_KEY=               # console.groq.com — fastest free inference
CEREBRAS_API_KEY=           # cloud.cerebras.ai
GOOGLE_AI_STUDIO_API_KEY=   # aistudio.google.com — Gemini free tier
MISTRAL_API_KEY=            # console.mistral.ai
OPENROUTER_API_KEY=         # openrouter.ai — :free models
